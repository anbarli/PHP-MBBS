# Admin Panel Configuration Example
# Bu dosyayı admin.env olarak kopyalayın ve kendi değerlerinizi girin

ADMIN_USERNAME=admin
# Use password_hash() output (bcrypt/argon2). Example below is for "ChangeMe123!".
ADMIN_PASSWORD=$2y$10$EUnEH4xeM89XvK5glW4Q7ef6vGxE7Wn66iRS0LlwM651c01qmPvNW
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
SESSION_TIMEOUT=7200
MAX_UPLOAD_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp 
